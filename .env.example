# Google AI API Key (required for Jarvis chatbot and embedding generation)
# Get your key at: https://aistudio.google.com/apikey
# Used at runtime for chat + query embedding, and at build time for knowledge embedding
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Override the Gemini model (default: gemini-2.0-flash-lite)
# Options: gemini-2.0-flash, gemini-2.0-flash-lite, gemini-2.5-flash-preview-04-17
# GEMINI_MODEL=gemini-2.0-flash

# LangSmith Observability (optional -- traces Jarvis Q&A in LangSmith dashboard)
# Sign up at: https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=your_project_name
# LANGCHAIN_CALLBACKS_BACKGROUND=false

# Instagram sync (build-time, via scripts/sync-instagram.py + instaloader)
# Requires `pip install instaloader` on the build machine.
INSTAGRAM_USERNAME=nerdguytheory
INSTAGRAM_MAX_POSTS=24
# Optional: authenticated session for higher rate limits / private account access.
# One-time setup (interactive): instaloader --login=<your_handle>
# Then point the script at the saved session by setting:
# INSTAGRAM_LOGIN_USER=your_handle
